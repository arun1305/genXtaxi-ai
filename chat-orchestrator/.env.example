# ── chat-orchestrator environment (spec §2) ─────────────────────────────────
NODE_ENV=development
PORT=8082

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genxtaxi_ai?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# JWT — same secret as gen-taxi-backend (forwarded caller token is validated here too)
JWT_SECRET=change-me-to-match-gen-taxi-backend
JWT_ALGORITHM=HS256

# Downstream services
AI_GATEWAY_URL=http://localhost:8080
GEN_TAXI_BACKEND_URL=http://localhost:5001
CURRENCY_SERVICE_URL=http://localhost:8081

# Tool-calling loop
MAX_TOOL_HOPS=5
SESSION_CONTEXT_TURNS=10
CHAT_RETENTION_DAYS=90

# Guardrails
REFUND_MAX_PER_DAY=3
CONFIRM_TTL_SECONDS=300

# Market / localization
MARKET=Algeria
DEFAULT_LANG=fr
