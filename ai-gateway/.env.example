# ── ai-gateway environment (spec §1, §5) ─────────────────────────────────────
NODE_ENV=development
PORT=8080

# MongoDB Atlas (Mongoose) — same cluster as the rest of GenXTaxi
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genxtaxi_ai?retryWrites=true&w=majority

# Redis (online cache: token budgets, FX cache, circuit-breaker state)
REDIS_URL=redis://localhost:6379

# JWT — MUST match gen-taxi-backend so the gateway validates the same tokens
JWT_SECRET=change-me-to-match-gen-taxi-backend
JWT_ALGORITHM=HS256
JWT_ISSUER=genxtaxi

# ── Provider routing (spec §1 LLM provider strategy) ────────────────────────
GROQ_API_KEY=
# Host only — the groq-sdk appends /openai/v1/chat/completions itself.
GROQ_BASE_URL=https://api.groq.com
LLM_CHAT_MODEL=llama-3.3-70b-versatile
LLM_CHEAP_MODEL=llama-3.1-8b-instant

# Fallback provider
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Embeddings (Groq has none). Provider: cohere (production, needs COHERE_API_KEY)
# or local (deterministic hash embeddings, no key — dev/CI/offline; lower quality).
EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=
EMBEDDING_MODEL=embed-multilingual-v3.0
EMBEDDING_DIMENSIONS=1024

# ── Cost controls (spec §1 Cost controls, §5) ───────────────────────────────
DAILY_TOKEN_BUDGET_PER_USER=100000
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=60

# Retention (TTL) for chat/logs in days (spec §5 Data retention)
AI_LOG_RETENTION_DAYS=90

# currency-service base URL (money conversions / cost normalization)
CURRENCY_SERVICE_URL=http://localhost:8081

# demand-service base URL (heatmap + advisory surge proxy — spec §4.3)
DEMAND_SERVICE_URL=http://localhost:8084
REPORTING_BASE_CURRENCY=USD

# Circuit breaker
CB_TIMEOUT_MS=15000
CB_ERROR_THRESHOLD_PERCENT=50
CB_RESET_TIMEOUT_MS=30000
