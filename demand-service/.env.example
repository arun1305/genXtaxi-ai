# ── demand-service environment (spec §4) ────────────────────────────────────
ENV=development
PORT=8084

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genxtaxi_ai?retryWrites=true&w=majority
MONGODB_DB=genxtaxi_ai
REDIS_URL=redis://localhost:6379

# JWT — same secret as gen-taxi-backend (validates { id, role }; no issuer)
JWT_SECRET=change-me-to-match-gen-taxi-backend
JWT_ALGORITHM=HS256

# Geospatial
H3_RESOLUTION=8
WINDOW_MINUTES=15

# Surge engine (ADVISORY/shadow — not wired to live fares this phase)
MAX_SURGE=2.0
SURGE_STEP=0.1
SURGE_MAX_STEP_CHANGE=0.3
SURGE_MIN_DWELL_SECONDS=300
SURGE_EWMA_ALPHA=0.5
SURGE_ADVISORY=true

# Prediction cadence
PREDICT_CRON_SECONDS=300
PREDICT_HORIZON_WINDOWS=8
RETRAIN_NIGHTLY_CRON=0 3 * * *
RETRAIN_WEEKLY_CRON=0 4 * * 0

# Cold start / confidence
MIN_TRAIN_ROWS=500
