# ── insights-service environment (spec §3) ──────────────────────────────────
NODE_ENV=development
PORT=8083

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genxtaxi_ai?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-match-gen-taxi-backend
JWT_ALGORITHM=HS256

# ai-gateway for aspect extraction / summarization / embeddings
AI_GATEWAY_URL=http://localhost:8080
# A long-lived service admin JWT the batch pipeline uses to call ai-gateway
INSIGHTS_SERVICE_TOKEN=

# Batch triggers (spec §3.2)
SUMMARY_MIN_NEW_REVIEWS=5
SUMMARY_MAX_AGE_HOURS=24
INGEST_CRON=*/5 * * * *
ZONE_AGGREGATION_CRON=0 2 * * *
COLD_START_MIN_REVIEWS=5

# Determinism (spec §3.7)
SUMMARY_PROMPT_VERSION=1
SUMMARY_TEMPERATURE=0.1

# Cache
SUMMARY_CACHE_TTL_SECONDS=86400
DEFAULT_LANG=fr
