# ── currency-service environment (spec §1 Money & multi-currency) ───────────
NODE_ENV=development
PORT=8081

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genxtaxi_ai?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# JWT — same secret as gen-taxi-backend (admin-only mutations)
JWT_SECRET=change-me-to-match-gen-taxi-backend
JWT_ALGORITHM=HS256
JWT_ISSUER=genxtaxi

# FX provider (spec §1: pulled from a rates provider, cached in Redis, refreshed on schedule)
FX_PROVIDER=exchangerate.host
FX_API_URL=https://api.exchangerate.host/latest
FX_API_KEY=
FX_BASE_CURRENCY=DZD
FX_REFRESH_CRON=0 */6 * * *
FX_CACHE_TTL_SECONDS=21600

# Base reporting currency for admin dashboards (spec §1)
REPORTING_BASE_CURRENCY=USD
